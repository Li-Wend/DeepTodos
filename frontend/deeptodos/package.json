{
  "name": "deeptodos",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "openapi-ts": "openapi-ts",
    "lint": "eslint src --ext .js,.vue,.ts",
    "lint:fix": "eslint src --ext .js,.vue,.ts --fix",
    "format": "prettier --write \"src/**/*.{js,vue,ts,tsx,css,scss,json}\"",
    "format:check": "prettier --check \"src/**/*.{js,vue,ts,tsx,css,scss,json}\"",
    "prepare": "husky"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "element-plus": "^2.12.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.25",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@hey-api/openapi-ts": "^0.94.0",
    "@tsconfig/node24": "^24.0.3",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "happy-dom": "^20.8.7",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.4.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.1",
    "sass": "^1.97.0",
    "terser": "^5.46.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "unplugin-auto-import": "^20.3.0",
    "unplugin-vue-components": "^30.0.0",
    "unplugin-vue-router": "^0.19.2",
    "vite": "^7.2.4",
    "vite-plugin-vue-devtools": "^8.0.5",
    "vite-plugin-vue-layouts": "^0.11.0",
    "vite-svg-loader": "^5.1.0",
    "vitest": "^4.1.1",
    "vue-tsc": "^3.1.5"
  },
  "lint-staged": {
    "src/**/*.{js,vue,ts,tsx,css,scss,json}": [
      "prettier --write"
    ],
    "src/**/*.{js,vue,ts,tsx}": [
      "eslint --fix"
    ]
  }
}
